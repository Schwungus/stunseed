{
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "file",
    "C_Cpp.intelliSenseEngine": "disabled",
    "files.associations": {
        "*.h.in": "c",
        "*.h": "c"
    },
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        ".cache": true
    }
}
